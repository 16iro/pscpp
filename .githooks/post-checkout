#!/usr/bin/env bash
# git clone / checkout 후 .env 가 없으면 자동 생성

ROOT="$(cd "$(dirname "$0")/../.." && pwd)"
ENV_FILE="$ROOT/.env"
EXAMPLE_FILE="$ROOT/.env.example"

[[ -f "$ENV_FILE" ]] && exit 0   # 이미 존재하면 스킵

echo "[pscpp] .env 파일이 없습니다. 자동 생성합니다..."

# MSYS2 경로 탐색 (Windows)
MSYS2_ROOT="C:/msys64"
for candidate in "C:/msys64" "C:/msys2" "$HOME/msys64"; do
    if [[ -f "$candidate/usr/bin/bash.exe" ]]; then
        MSYS2_ROOT="$candidate"
        break
    fi
done

# 컴파일러 감지 (cl.exe 있으면 msvc, 없으면 gcc)
if command -v cl.exe > /dev/null 2>&1; then
    COMPILER="msvc"
else
    COMPILER="gcc"
fi

cat > "$ENV_FILE" <<EOF
MSYS2_ROOT=${MSYS2_ROOT//\//\\}
COMPILER=$COMPILER
EOF

echo "[pscpp] .env 생성 완료 (MSYS2_ROOT=${MSYS2_ROOT}, COMPILER=${COMPILER})"
echo "[pscpp] 경로가 다르다면 .env 를 직접 수정하세요."
